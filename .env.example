# Copy to `.env` or inject the same keys via Docker / K8s / your secret manager.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

INNOVATION_LABS_DOCS=
INNOVATION_LAB_AGENTS=
DOC_URL_MANIFEST=
INNOVATION_LABS_DOC_BASE=https://innovationlab.fetch.ai/resources/docs

PORT=8000
# Comma-separated: Vercel app + local Next (`npm run dev`). No trailing slash.
API_CORS_ORIGINS=https://hackathon-evaluator-one.vercel.app,http://localhost:3000

# Optional: keep temp clone for debugging (unset in prod)
EVAL_PERSIST_CLONE=

# Optional: override bundled prompts directory
PROMPTS_DIR=
